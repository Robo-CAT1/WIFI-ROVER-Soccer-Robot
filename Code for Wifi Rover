// ===========================
// Motor control functions
// ===========================
void stopMotors() {
  //To stop the motors
 digitalWrite(MOTOR_IN1, LOW);
 digitalWrite(MOTOR_IN2, LOW);
 digitalWrite(MOTOR_IN3, LOW);
 digitalWrite(MOTOR_IN4, LOW);
}


void moveForward() {
  //To turn the robot forwards, this section gets both motors to move counter-clockwise
 digitalWrite(MOTOR_IN1, LOW);
 digitalWrite(MOTOR_IN2, HIGH);
 digitalWrite(MOTOR_IN3, LOW);
 digitalWrite(MOTOR_IN4, HIGH);
}


void moveBackward() {
  //To turn the robot backwards, this section gets both motos to move clockwise
 digitalWrite(MOTOR_IN1, HIGH);
 digitalWrite(MOTOR_IN2, LOW);
 digitalWrite(MOTOR_IN3, HIGH);
 digitalWrite(MOTOR_IN4, LOW);
}


void turnLeft() {
  //To turn the robot left, this section gets the left motor to move counter-clockwise and the right motor to move clockwise
 digitalWrite(MOTOR_IN3, HIGH);
 digitalWrite(MOTOR_IN4, LOW);
 digitalWrite(MOTOR_IN1, LOW);
 digitalWrite(MOTOR_IN2, HIGH);
}


void turnRight() {
  //To turn the robot right, this section gets the left motor to move clockwise and the right motor to move counter-clockwise
 digitalWrite(MOTOR_IN3, LOW);
 digitalWrite(MOTOR_IN4, HIGH);
 digitalWrite(MOTOR_IN1, HIGH);
 digitalWrite(MOTOR_IN2, LOW);
}


